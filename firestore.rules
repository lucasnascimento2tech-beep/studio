
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && getUserData().globalRole == 'admin_2tech';
    }
    
    function isImplantador() {
      return isAuthenticated() && getUserData().globalRole == 'implantador';
    }

    function isClientMaster(companyId) {
      let user = getUserData();
      return isAuthenticated() && user.globalRole == 'client_master' && user.companyId == companyId;
    }

    function belongsToCompany(companyId) {
      return isAuthenticated() && getUserData().companyId == companyId;
    }

    function belongsToImplementation(implId) {
      return isAuthenticated() && getUserData().implementationId == implId;
    }

    match /users/{uid} {
      allow read: if isAuthenticated() && (request.auth.uid == uid || isAdmin() || isImplantador());
      allow create: if isAdmin() || (isAuthenticated() && request.auth.uid == uid);
      allow update: if isAdmin() || isImplantador() || (
        isAuthenticated() && 
        request.auth.uid == uid && 
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['globalRole', 'active', 'companyId', 'implementationId', 'uid', 'email', 'approvalStatus'])
      );
      allow delete: if isAdmin();
    }

    match /accessRequests/{requestId} {
      allow read: if isAdmin() || isImplantador() || (isAuthenticated() && resource.data.uid == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update: if isAdmin() || isImplantador();
      allow delete: if isAdmin();
    }

    match /companies/{companyId} {
      // Implantador só lê se for o responsável pela empresa ou se for admin
      allow read: if isAdmin() || belongsToCompany(companyId) || (isImplantador() && (
        resource.data.mainImplantadorUid == request.auth.uid || 
        get(/databases/$(database)/documents/implementations/$(resource.data.activeImplementationId)).data.assignedImplantadorUid == request.auth.uid
      ));
      allow write: if isAdmin() || isImplantador();
    }

    match /implementations/{implId} {
      // Implantador só lê se for o responsável pela implantação ou se for admin
      allow read: if isAdmin() || (isImplantador() && resource.data.assignedImplantadorUid == request.auth.uid) || belongsToImplementation(implId);
      allow update: if isAdmin() || (isImplantador() && resource.data.assignedImplantadorUid == request.auth.uid);
      allow create, delete: if isAdmin() || isImplantador();
    }

    match /implementationMembers/{memberId} {
      allow read: if isAdmin() || isImplantador() || belongsToImplementation(resource.data.implementationId);
      allow create: if isAdmin() || isImplantador() || (isAuthenticated() && isClientMaster(request.resource.data.companyId));
      allow update, delete: if isAdmin() || isImplantador() || (isAuthenticated() && isClientMaster(resource.data.companyId));
    }

    match /invites/{inviteId} {
      allow read: if true;
      allow create: if isAdmin() || isImplantador() || (isAuthenticated() && isClientMaster(request.resource.data.companyId));
      allow update, delete: if isAdmin() || isImplantador() || (isAuthenticated() && isClientMaster(resource.data.companyId));
    }

    match /moduleProgress/{progressId} {
      allow read: if isAdmin() || isImplantador() || belongsToImplementation(resource.data.implementationId);
      allow write: if isAuthenticated() && (
        request.auth.uid == request.resource.data.uid || 
        isAdmin() || 
        isImplantador()
      );
    }

    match /meetings/{meetingId} {
      allow read: if isAdmin() || isImplantador() || belongsToImplementation(resource.data.implementationId);
      allow create: if isAdmin() || isImplantador() || (isAuthenticated() && isClientMaster(request.resource.data.companyId));
      allow update: if isAdmin() || isImplantador() || (isAuthenticated() && isClientMaster(resource.data.companyId));
    }

    match /quizSubmissions/{subId} {
      allow read: if isAdmin() || isImplantador() || belongsToImplementation(resource.data.implementationId);
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.uid;
    }
  }
}
