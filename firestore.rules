
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Admin access
    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.globalRole == 'admin_2tech';
    }
    
    // Implantador access
    function isImplantador() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.globalRole == 'implantador';
    }

    // Client Master access
    function isClientMaster(companyId) {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.globalRole == 'client_master' &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId == companyId;
    }

    match /users/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin() || isImplantador());
      allow write: if isAdmin() || (request.auth != null && request.auth.uid == uid);
    }

    match /companies/{companyId} {
      allow read: if request.auth != null && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId == companyId || isAdmin() || isImplantador());
      allow write: if isAdmin();
    }

    match /implementations/{implId} {
      allow read: if request.auth != null && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.implementationId == implId || isAdmin() || isImplantador());
      allow write: if isAdmin() || isImplantador();
    }

    match /implementationMembers/{memberId} {
      allow read: if request.auth != null && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.implementationId == resource.data.implementationId || isAdmin() || isImplantador());
      allow create: if isAdmin() || (request.auth != null && isClientMaster(request.resource.data.companyId));
      allow update, delete: if isAdmin() || (request.auth != null && isClientMaster(resource.data.companyId));
    }

    match /invites/{inviteId} {
      allow read: if true; // Needed for token verification
      allow create: if isAdmin() || (request.auth != null && isClientMaster(request.resource.data.companyId));
      allow update, delete: if isAdmin() || (request.auth != null && isClientMaster(resource.data.companyId));
    }

    match /moduleProgress/{progressId} {
      allow read: if request.auth != null && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.implementationId == resource.data.implementationId || isAdmin() || isImplantador());
      allow write: if request.auth != null && (request.auth.uid == request.resource.data.uid || isAdmin() || isImplantador());
    }

    match /meetings/{meetingId} {
      allow read: if request.auth != null && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.implementationId == resource.data.implementationId || isAdmin() || isImplantador());
      allow create: if isAdmin() || (request.auth != null && isClientMaster(request.resource.data.companyId));
      allow update: if isAdmin() || isImplantador() || (request.auth != null && isClientMaster(resource.data.companyId));
    }
  }
}
